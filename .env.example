# Frontend development deployment variables
NEXT_PUBLIC_SITE_URL=https://agency.example.com

# Optional blog CMS (Sanity) integration
# If these are unset, the blog falls back to local static content.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
SANITY_API_TOKEN=

# Live Google review sections. Use a browser/referrer-restricted Google Maps key.
# Enable both the Google Maps JavaScript API and the Places API for this key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Prefer the stable Place ID once known. The app can fall back to the search text
# during setup or while the Place ID is being confirmed.
NEXT_PUBLIC_GOOGLE_PLACE_ID=
NEXT_PUBLIC_GOOGLE_PLACE_SEARCH_TEXT=Growrix OS, 82, 1 Rd-2, Dhaka 1212, Bangladesh

# Server-side contact and booking delivery
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_FROM_FALLBACK_EMAIL=Growrix <onboarding@resend.dev>
RESEND_API_KEY=

# Server-only AI concierge configuration
OPENAI_API_KEY=
OPENAI_MODEL=o3-mini

# Admin auth and session signing
AUTH_JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Stripe checkout and webhook delivery
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Abuse-protection thresholds
RATE_LIMIT_CONTACT_PER_MINUTE=6
RATE_LIMIT_BOOKING_PER_MINUTE=6
RATE_LIMIT_CONCIERGE_PER_MINUTE=12
RATE_LIMIT_AUTH_PER_MINUTE=10