/* Extracted component CSS — paste into app/globals.css @layer components */

.container{max-width:var(--maxw);margin:0 auto;padding-inline:clamp(20px,5vw,64px)}

.btn{display:inline-flex;align-items:center;justify-content:center;gap:9px;font-family:var(--fb);font-weight:600;font-size:15px;padding:13px 22px;border-radius:var(--rb);border:1px solid transparent;line-height:1;cursor:pointer;transition:transform .18s,background .2s,color .2s,border-color .2s,box-shadow .2s;white-space:nowrap}

.btn:hover{transform:translateY(-2px)}

.btn svg{width:16px;height:16px;flex-shrink:0}

.btn-p{background:var(--accent);color:#fff;box-shadow:0 10px 30px -12px rgba(255,90,31,.5)}

.btn-s{background:transparent;color:var(--text);border-color:var(--borders)}

.btn-s:hover{background:var(--surface)}

.btn-g{background:rgba(255,255,255,.08);color:#fff;border-color:rgba(255,255,255,.22);backdrop-filter:blur(6px)}

.btn-g:hover{background:rgba(255,255,255,.14)}

.btn-full{width:100%}

.btn-lg{padding:15px 28px;font-size:16px}

.navbar{position:sticky;top:0;z-index:60;transition:background .3s,border-color .3s;border-bottom:1px solid transparent}

.navbar.scrolled{background:rgba(11,12,14,.85);backdrop-filter:saturate(180%) blur(14px);border-color:var(--border)}

.drawer{position:fixed;inset:0;z-index:80;background:var(--bg);padding:24px;flex-direction:column;transform:translateX(100%);transition:transform .35s cubic-bezier(.16,1,.3,1);display:none}

.drawer.open{transform:translateX(0)}

.drawer-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:32px}

.drawer-links{display:grid;gap:6px}

.drawer-link{display:flex;justify-content:space-between;align-items:center;font-family:var(--fd);font-weight:700;font-size:30px;color:var(--text);padding:12px 0;border-bottom:1px solid var(--border)}

.drawer-num{font-family:var(--fm);font-size:13px;color:var(--faint)}

.fab-wrap{position:fixed;right:20px;bottom:28px;z-index:70;display:flex;flex-direction:column;align-items:center;gap:10px}

.fab-main{width:54px;height:54px;border-radius:50%;background:var(--accent);color:#fff;display:grid;place-items:center;box-shadow:0 12px 28px -10px rgba(0,0,0,.55);cursor:pointer;transition:transform .2s,background .2s;border:none}

.fab-main:hover{transform:scale(1.08)}

.fab-main.open{background:var(--borders)}

.fab-opts{display:flex;flex-direction:column;align-items:center;gap:10px;overflow:hidden;max-height:0;opacity:0;transition:max-height .4s cubic-bezier(.16,1,.3,1),opacity .3s}

.fab-opts.open{max-height:260px;opacity:1}

.fab-opt{width:48px;height:48px;border-radius:50%;display:grid;place-items:center;box-shadow:0 8px 20px -8px rgba(0,0,0,.5);cursor:pointer;transition:transform .2s;text-decoration:none;position:relative}

.fab-opt:hover{transform:scale(1.1)}

.fab-opt.call{background:var(--surface2);color:var(--text)}

.fab-opt.wa{background:#25D366;color:#fff}

.fab-opt.top{background:var(--surface2);color:var(--text);display:none}

.fab-tip{position:absolute;right:58px;top:50%;transform:translateY(-50%) translateX(4px);background:var(--elevated);color:var(--text);font-family:var(--fm);font-size:11px;padding:5px 10px;border-radius:8px;border:1px solid var(--border);white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .2s,transform .2s}

.fab-opt:hover .fab-tip{opacity:1;transform:translateY(-50%) translateX(0)}

.hero{position:relative;overflow:hidden;min-height:92vh;display:flex;align-items:center;background:var(--bg)}

.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center}

.hero-ov{position:absolute;inset:0}

.hero-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center;position:relative;z-index:2;width:100%}

.hero-h1{font-family:var(--fd);font-weight:800;color:#fff;font-size:clamp(2.6rem,7vw,5rem);line-height:.98;letter-spacing:-.03em;margin-top:20px}

.hero-sub{color:rgba(255,255,255,.82);font-size:19px;line-height:1.6;max-width:520px;margin-top:22px}

.hero-ctas{display:flex;flex-wrap:wrap;gap:14px;margin-top:32px}

.stats-s{position:relative;background:#0B0C0E;overflow:hidden;padding-block:clamp(64px,8vw,100px)}

.stats-glow{position:absolute;inset:0;background:radial-gradient(60% 80% at 50% 0%,rgba(255,90,31,.14),transparent 70%)}

.stats-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:24px}

.faq-item{border:1px solid var(--border);border-radius:var(--rb);background:var(--surface);margin-bottom:12px;overflow:hidden}

.faq-q{display:flex;justify-content:space-between;align-items:center;gap:14px;padding:16px 18px;cursor:pointer;font-weight:600;font-size:16px;color:var(--text);list-style:none}

.faq-q::-webkit-details-marker{display:none}

.faq-ico-p,.faq-ico-m{color:var(--accent);flex-shrink:0}

.faq-item .faq-ico-m{display:none}

.faq-item[open] .faq-ico-p{display:none}

.faq-item[open] .faq-ico-m{display:block}

.faq-a{padding:0 18px 16px;color:var(--muted);font-size:15px;line-height:1.6}

.page-hero{position:relative;overflow:hidden;padding-block:clamp(80px,10vw,140px);background:var(--bg)}

.footer-grid{display:grid;grid-template-columns:1.4fr repeat(4,1fr);gap:36px}

@media(max-width:1100px){
  .process-grid{grid-template-columns:repeat(4,1fr)}
  .stats-grid{grid-template-columns:repeat(3,1fr)}
  .grid4{grid-template-columns:repeat(2,1fr)}
  .footer-grid{grid-template-columns:1fr 1fr 1fr}
}

@media(max-width:880px){
  .hero-grid{grid-template-columns:1fr;gap:40px}
  .grid2{grid-template-columns:1fr}
  .grid3{grid-template-columns:1fr 1fr}
  .masonry{grid-template-columns:1fr 1fr;grid-auto-rows:180px}
  .awards-grid{grid-template-columns:1fr 1fr}
  .hamburger{display:grid}
  .nav-links,.btn-desktop{display:none!important}
  .drawer{display:flex}
  .bottom-nav{display:flex}
  .fab-wrap{bottom:90px}
}

@media(max-width:560px){
  .grid3{grid-template-columns:1fr}
  .grid4{grid-template-columns:1fr}
  .masonry{grid-template-columns:1fr;grid-auto-rows:auto}
  .masonry .proj{grid-row:span 1!important;min-height:300px!important}
  .process-grid{grid-template-columns:1fr 1fr}
  .stats-grid{grid-template-columns:1fr 1fr}
  .awards-grid{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr 1fr}
}

.btn-desktop{display:inline-flex}

@media(max-width:880px){.btn-desktop{display:none!important}}

@media(max-width:880px){
  .bottom-nav{display:flex}
  body{padding-bottom:90px}
  .fab-wrap{bottom:90px}
}
